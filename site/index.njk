---
permalink: "/index.html"
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>David Gomez</title>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
{%- set ogTitle = title or site.name %}
{%- set ogDesc = description or site.description %}
{%- set ogImage = site.url + (image or "/og.png") %}
<meta property="og:type" content="website">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ ogTitle }}">
<meta property="og:description" content="{{ ogDesc }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ ogImage }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="{{ ogTitle }}{% if ogTitle != site.name %} - {{ site.name }}{% endif %}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle }}">
<meta name="twitter:description" content="{{ ogDesc }}">
<meta name="twitter:image" content="{{ ogImage }}">
<link rel="icon" type="image/png" href="/favicon.png">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<link rel="stylesheet" href="/swiss.css">
</head>
<body>
<nav><a href="index.html" class="nav-logo">DG<span class="dot"></span></a><ul class="nav-links"><li><a href="index.html" class="active">Home</a></li><li><a href="work.html">Work</a></li><li><a href="davidisdeploying.html">Projects</a></li><li><a href="devblog.html">Devblog</a></li><li><a href="stack.html">Stack</a></li><li><a href="resume.html">Résumé</a></li></ul></nav>
<main class="wrap">

  <div class="mast"><span>davidgomez.cc</span><span>Plano, TX &middot; 2026</span></div>

  <section class="hero">
    <h1 class="hugename reveal"><span style="animation-delay:.05s">David</span><span class="dot" style="animation-delay:.16s">Gomez.</span></h1>
    <div class="herorow">
      <p class="role">Configuration Technician working where enterprise IT, hardware, and the <b>defense supply chain</b> meet.</p>
      <div class="meta">
        <div><span class="k">Role</span><span class="v">Config Technician</span></div>
        <div><span class="k">Sector</span><span class="v">Defense IT</span></div>
        <div><span class="k">Based</span><span class="v">Plano, TX</span></div>
        <div><span class="k">Status</span><span class="v live">In service</span></div>
      </div>
    </div>
  </section>

  <section class="indexsec">
    <h2>Index</h2>
    <div class="idx">
      <a href="work.html" class="ent"><span class="no">01</span><span class="body"><span class="nm">Work</span><span class="ds">Configuring enterprise hardware for the security-conscious.</span></span><span class="ar">&#8599;</span></a>
      <a href="davidisdeploying.html" class="ent"><span class="no">02</span><span class="body"><span class="nm">Projects</span><span class="ds">Loupe, Tandem, this site, and the stack behind each.</span></span><span class="ar">&#8599;</span></a>
      <a href="devblog.html" class="ent"><span class="no">03</span><span class="body"><span class="nm">Devblog</span><span class="ds">Near-daily logs: what got made, what broke, what I learned.</span></span><span class="ar">&#8599;</span></a>
      <a href="/stack.html" class="ent"><span class="no">04</span><span class="body"><span class="nm">Stack</span><span class="ds">Every technology I've touched, sized by how often it comes up.</span></span><span class="ar">&#8599;</span></a>
      <a href="resume.html" class="ent"><span class="no">05</span><span class="body"><span class="nm">R&eacute;sum&eacute;</span><span class="ds">Work history, skills, and education in full.</span></span><span class="ar">&#8599;</span></a>
      <a href="https://loupeculling.com" class="ent" target="_blank" rel="noopener"><span class="no">06</span><span class="body"><span class="nm">Loupe</span><span class="ds">The self-hosted photo culler I'm building. Look, cull, loop.</span></span><span class="ar">&#8599;</span></a>
    </div>
  </section>

  {%- if collections.topicmap.nodes | length %}
  <section class="homemap">
    <div class="top"><h2>Everything I've touched</h2><a class="maplink" href="/stack.html">Full map &rarr;</a></div>
    <div class="bubblewrap">
      <svg class="bubbles" viewBox="0 0 {{ collections.topicmap.w }} {{ collections.topicmap.h }}" role="img" aria-label="Topics sized by frequency">
        <defs>
          <radialGradient id="orb" cx="48%" cy="40%" r="68%">
            <stop offset="0%" stop-color="#ef5a45"/>
            <stop offset="62%" stop-color="#e5331c"/>
            <stop offset="100%" stop-color="#c32a14"/>
          </radialGradient>
        </defs>
        {%- for n in collections.topicmap.nodes %}
        <a href="/devblog/topic/{{ n.slug }}.html" class="orb"><title>{{ n.topic }} - {{ n.count }} post{% if n.count != 1 %}s{% endif %}</title>
          <circle cx="{{ n.x }}" cy="{{ n.y }}" r="{{ n.r }}" fill="url(#orb)"/>
          <text class="cnt" x="{{ n.x }}" y="{{ n.cyCount }}" style="font-size:{{ n.cfont }}px">{{ n.count }}</text>
          {%- if n.showLabel %}<text class="lbl" x="{{ n.x }}" y="{{ n.cyLabel }}" style="font-size:{{ n.lfont }}px">{{ n.topic }}</text>{% endif %}
        </a>
        {%- endfor %}
      </svg>
    </div>
  </section>
  {%- endif %}
</main>
<footer><span class="footer-name">David Gomez &middot; Plano, TX</span><div class="footer-links"><a href="mailto:david@davidgomez.cc">Email</a><a href="https://www.linkedin.com/in/davidisdeploying/" target="_blank">LinkedIn</a></div></footer>
<script defer src="/swiss.js"></script>
</body>
</html>
