<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} &middot; David Gomez</title>
<link rel="alternate" type="application/rss+xml" title="David Gomez - Devblog" href="/feed.xml">
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
{%- set ogTitle = title or site.name %}
{%- set ogDesc = description or site.description %}
{%- set ogImage = site.url + (image or "/og.png") %}
<meta property="og:type" content="website">
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ ogTitle }}">
<meta property="og:description" content="{{ ogDesc }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:image" content="{{ ogImage }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="{{ ogTitle }}{% if ogTitle != site.name %} - {{ site.name }}{% endif %}">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle }}">
<meta name="twitter:description" content="{{ ogDesc }}">
<meta name="twitter:image" content="{{ ogImage }}">
<link rel="icon" type="image/png" href="/favicon.png">
<link rel="apple-touch-icon" href="/apple-touch-icon.png">
<link rel="stylesheet" href="/swiss.css">
</head>
<body>
<nav><a href="/index.html" class="nav-logo"><span class="dot"></span>DG</a><ul class="nav-links"><li><a href="/index.html">Home</a></li><li><a href="/work.html">Work</a></li><li><a href="/davidisdeploying.html">Projects</a></li><li><a href="/devblog.html"{% if "/devblog" in page.url %} class="active"{% endif %}>Devblog</a></li><li><a href="/stack.html"{% if page.url == "/stack.html" %} class="active"{% endif %}>Stack</a></li><li><a href="/resume.html">Résumé</a></li></ul></nav>
{{ content | safe }}
<footer><span class="footer-name">DAVID GOMEZ &middot; Plano, TX</span><div class="footer-links"><a href="mailto:david@davidgomez.cc">Email</a><a href="https://www.linkedin.com/in/davidisdeploying/" target="_blank">LinkedIn</a></div></footer>
<script defer src="/swiss.js"></script>
</body>
</html>
