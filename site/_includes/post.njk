---
layout: base.njk
---
<div class="postwrap">
  <a class="backlink" href="/devblog.html">&larr; All posts</a>
  <div class="posthead">
    <div class="postdate">{{ date | readable }}</div>
    <h1 class="posttitle" style="--vt-name:post-{{ page.fileSlug }}">{{ title }}</h1>
    {%- if topics %}
    <div class="topics">{% for t in topics %}<a href="/devblog/topic/{{ t | topicSlug }}.html">{{ t }}</a>{% endfor %}</div>
    {%- endif %}
  </div>
  <article class="post-body">{{ content | safe }}</article>
</div>
